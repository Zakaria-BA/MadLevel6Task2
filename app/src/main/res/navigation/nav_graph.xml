<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph.xml"
    app:startDestination="@id/movieOverviewFragment">

    <fragment
        android:id="@+id/movieOverviewFragment"
        android:name="com.example.madlevel6task2.ui.MovieOverviewFragment"
        android:label="movie_overview_fragment"
        tools:layout="@layout/movie_overview_fragment" >
        <action
            android:id="@+id/action_movieOverviewFragment_to_movieDetailFragment"
            app:destination="@id/movieDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/movieDetailFragment"
        android:name="com.example.madlevel6task2.ui.MovieDetailFragment"
        android:label="movie_detail_fragment"
        tools:layout="@layout/movie_detail_fragment" >
        <action
            android:id="@+id/action_movieDetailFragment_to_movieOverviewFragment"
            app:destination="@id/movieOverviewFragment" />
    </fragment>
</navigation>